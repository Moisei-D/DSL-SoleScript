{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SoleScript",
  "scopeName": "source.sole",
  "patterns": [
    { "include": "#comment" },
    { "include": "#block-keyword" },
    { "include": "#component-keyword" },
    { "include": "#condition-value" },
    { "include": "#unit" },
    { "include": "#number" },
    { "include": "#string" },
    { "include": "#punctuation" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.double-slash.sole",
      "match": "//.*$"
    },
    "block-keyword": {
      "name": "keyword.control.block.sole",
      "match": "\\b(Foot|Observations|Last|Boot|Export)\\b"
    },
    "component-keyword": {
      "name": "keyword.other.component.sole",
      "match": "\\b(Vamp|Tongue|Quarter|ToeBox|Outsole|Heel|Shank|Insole|Counter|Lining)\\b"
    },
    "condition-value": {
      "name": "constant.language.condition.sole",
      "match": "\\b(Diabetic|Egyptian|Greek|Roman|Celtic|Germanic|Square|Peasant)\\b"
    },
    "unit": {
      "name": "keyword.other.unit.sole",
      "match": "(?<=[0-9]\\s*)\\b(mm|cm)\\b"
    },
    "number": {
      "name": "constant.numeric.sole",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "string": {
      "name": "string.quoted.double.sole",
      "begin": "\"",
      "end": "\"",
      "patterns": []
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.section.block.begin.sole", "match": "\\{" },
        { "name": "punctuation.section.block.end.sole",   "match": "\\}" },
        { "name": "punctuation.section.list.begin.sole",  "match": "\\[" },
        { "name": "punctuation.section.list.end.sole",    "match": "\\]" },
        { "name": "punctuation.separator.key-value.sole", "match": ":" },
        { "name": "punctuation.separator.comma.sole",     "match": "," }
      ]
    },
    "identifier": {
      "name": "variable.other.sole",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
